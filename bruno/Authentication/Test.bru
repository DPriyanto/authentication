script:pre-request {
  const crypto = require('crypto');
  
  // Get the request body
  const bodyObject = req.getBody();
  const privateKey = 'abc143b70e4017530e7a9f5c9b6c7f80421af7a1041024d92b2246ca906281ea';
  
  // Convert to JSON string with consistent formatting (no spaces)
  const bodyString = JSON.stringify(bodyObject);
  
  // Sign the body
  const signature = crypto.createHmac('sha256', privateKey)
      .update(bodyString)
      .digest('base64');
  
  // Set the signature as a header
  req.setHeader('x-signature', signature);
  
  // Optional: Log for debugging
  console.log('Body string being signed:', bodyString);
  console.log('Generated signature:', signature);
}

settings {
  encodeUrl: true
  timeout: 0
}
